# =============================================================================
# Second Brain — frontend env (Vite, Phase 6: production-ready)
# =============================================================================
# This file is committed. Copy to .env.local for development; the repo's
# .gitignore blocks .env.local + .env.*.local from being committed.
#
# IMPORTANT: anything prefixed with VITE_ is BUNDLED INTO THE
# JAVASCRIPT THE BROWSER DOWNLOADS. Only put values here that are safe
# to expose publicly:
#
#   - VITE_API_BASE_URL       safe (the API origin is public anyway)
#   - VITE_SUPABASE_URL       safe (public Supabase project URL)
#   - VITE_SUPABASE_ANON_KEY  safe (Postgres RLS enforces per-user access)
#   - VITE_APP_API_KEY        DO NOT USE IN PRODUCTION (see below)
#
# On Vercel, set these in:
#   Project Settings -> Environment Variables
# Then add them to BOTH "Production" and "Preview" scopes so PR
# preview deploys can talk to your staging backend.
# =============================================================================


# ---------------------------------------------------------------------
# Backend base URL — REQUIRED
# ---------------------------------------------------------------------
# LOCAL DEV:
#     http://127.0.0.1:8000
# PRODUCTION (point at your deployed FastAPI):
#     https://your-backend.onrender.com
#     https://your-backend.up.railway.app
#
# Whatever you set here MUST appear in the backend's CORS_ORIGINS in
# reverse (the backend allows browser requests FROM this origin).
VITE_API_BASE_URL=http://127.0.0.1:8000


# ---------------------------------------------------------------------
# Supabase — REQUIRED
# ---------------------------------------------------------------------
# Supabase Dashboard -> Settings -> API.
# The anon key is intentionally public; per-user access is enforced
# by Postgres RLS policies (see backend/supabase/schema.sql). Don't
# put the service-role key here -- that goes in the BACKEND env only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key


# ---------------------------------------------------------------------
# Legacy admin-status key — OPTIONAL, LOCAL DEV ONLY
# ---------------------------------------------------------------------
# Enables the "Admin Status" card in the UI by sending X-API-Key to
# the backend's /api/admin/status route. Phase 6 strongly discourages
# shipping this to production -- the value would be readable by anyone
# who views the browser bundle. Leave BLANK on Vercel deployments and
# rely on backend-side observability (Render/Railway logs, dashboards)
# instead.
#
# Local dev only:
#     VITE_APP_API_KEY=your-local-only-key
VITE_APP_API_KEY=