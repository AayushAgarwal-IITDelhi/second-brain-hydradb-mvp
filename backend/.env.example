# Required — the app refuses to start without these.
APP_API_KEY=your-secret-api-key
HYDRADB_API_KEY=your-hydradb-key
HYDRADB_TENANT_ID=your-tenant-id
OPENAI_API_KEY=your-openai-key

# Supabase (Phase 1 multi-user auth) — also required.
# All three come from Supabase Dashboard -> Settings -> API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional HydraDB
HYDRADB_BASE_URL=https://api.hydradb.com
HYDRADB_SUB_TENANT_ID=slack-second-brain

# Optional OpenAI / OpenAI-compatible endpoint
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500

# Slack ingestion
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_IDS=C0123456,C9876543
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_LIMIT_PER_CHANNEL=500
HYDRADB_BATCH_SIZE=50
FORCE_REINGEST=false

# Realtime ingestion
REALTIME_INGEST_ENABLED=true

# Scheduled ingestion
AUTO_INGEST=false
AUTO_INGEST_INTERVAL_MINUTES=15
AUTO_INGEST_RUN_ON_STARTUP=false

# Recall / retrieval
DEBUG_RECALL=false

# Query cache
QUERY_CACHE_ENABLED=true

# Rate limiting
RATE_LIMIT_PER_5_MIN=20

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO