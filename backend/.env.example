# =============================================================================
# Second Brain — backend env (Phase 6: production-ready)
# =============================================================================
# This file is committed to the repo. Copy it to `.env` for local
# development and fill in real values. NEVER commit `.env` itself
# (the repo's .gitignore blocks it).
#
# In production (Render / Railway), DO NOT upload an .env file -- set
# each variable in the host's secret manager. The app reads the same
# variables either way (os.getenv).
#
# Format conventions:
#   - "REQUIRED" markers: backend/startup.py refuses to boot without these.
#   - "OPTIONAL" markers: the app has a sensible default; override only
#     when needed.
#   - Comments above each var explain what it's for and where to get it.
# =============================================================================


# ---------------------------------------------------------------------
# Core service secrets — REQUIRED
# ---------------------------------------------------------------------
# Shared secret for the legacy /api/admin/status route. Pick something
# long and random; pre-Phase-1 clients used it for /api/query too, but
# that route now uses Supabase auth.
APP_API_KEY=replace-with-a-long-random-string

# HydraDB credentials. The tenant_id is the project-wide id; the
# sub_tenant_id (below, optional) is the legacy fallback used by the
# CLI ingestion -- per-workspace sub-tenants are derived from the
# workspace's UUID (see Phase 4).
HYDRADB_API_KEY=your-hydradb-key
HYDRADB_TENANT_ID=your-tenant-id

# OpenAI (or any OpenAI-compatible provider's) key. Set OPENAI_BASE_URL
# below if you're using OpenRouter / Groq / Together / etc.
OPENAI_API_KEY=your-openai-key


# ---------------------------------------------------------------------
# Supabase (Phase 1 multi-user auth) — REQUIRED
# ---------------------------------------------------------------------
# All three come from Supabase Dashboard -> Settings -> API.
# The JWT secret is used to verify HS256 tokens; if your project has
# JWT Signing Keys enabled (ES256/RS256), the backend ALSO fetches the
# JWKS at {SUPABASE_URL}/auth/v1/.well-known/jwks.json automatically.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ---------------------------------------------------------------------
# Slack Connect (Phase 3 per-workspace OAuth) — REQUIRED
# ---------------------------------------------------------------------
# Create a Slack app at https://api.slack.com/apps. Under
# "OAuth & Permissions" add these BOT scopes:
#     channels:history  channels:read  groups:history
#     groups:read       users:read
# Then set the redirect URL to match SLACK_REDIRECT_URI below.
#
# SLACK_OAUTH_STATE_SECRET is a random string used to HMAC-sign the
# OAuth state token. Generate with:
#     python -c "import secrets; print(secrets.token_hex(32))"
SLACK_CLIENT_ID=your-slack-app-client-id
SLACK_CLIENT_SECRET=your-slack-app-client-secret

# --- SLACK_REDIRECT_URI ---
# LOCAL DEV (default):
#     http://127.0.0.1:8000/api/slack/oauth/callback
# PRODUCTION:
#     https://your-backend.onrender.com/api/slack/oauth/callback
# (must match exactly what you registered in the Slack app config)
SLACK_REDIRECT_URI=http://127.0.0.1:8000/api/slack/oauth/callback
SLACK_OAUTH_STATE_SECRET=replace-with-a-long-random-string

# --- SLACK_SIGNING_SECRET ---
# Used to verify the HMAC signature on incoming /slack/events
# webhooks. Find it under "Basic Information" -> "App Credentials"
# in the Slack app config. Same value local + prod.
SLACK_SIGNING_SECRET=your-slack-signing-secret


# ---------------------------------------------------------------------
# Gmail Connect (Phase 8 per-workspace Gmail OAuth) — OPTIONAL
# ---------------------------------------------------------------------
# When unset, /api/gmail/connect-url returns 503 and the connector is
# effectively disabled. The rest of the app boots fine without these.
#
# Create OAuth credentials at
#   https://console.cloud.google.com/apis/credentials
# (OAuth client ID -> Web application). Add to "Authorized redirect
# URIs" the value of GMAIL_REDIRECT_URI below.
#
# Scopes the connector requests (read-only -- we never modify or send):
#   openid  email  profile  https://www.googleapis.com/auth/gmail.readonly
#
# GMAIL_OAUTH_STATE_SECRET is a random string used to HMAC-sign the
# OAuth state token (separate from SLACK_OAUTH_STATE_SECRET on
# purpose). Generate with:
#     python -c "import secrets; print(secrets.token_hex(32))"
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# --- GMAIL_REDIRECT_URI ---
# LOCAL DEV (default):
#     http://127.0.0.1:8000/api/gmail/oauth/callback
# PRODUCTION:
#     https://your-backend.onrender.com/api/gmail/oauth/callback
GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback
GMAIL_OAUTH_STATE_SECRET=

# Ingestion caps + safety. The default GMAIL_MAX_MESSAGES_PER_RUN is
# 100 -- enough for a typical "newsletters" label, low enough that a
# stray click can't suck down a whole mailbox. SPAM/TRASH labels are
# blocked by default even if explicitly selected; set
# GMAIL_ALLOW_SPAM_TRASH=true to allow them.
GMAIL_MAX_MESSAGES_PER_RUN=100
GMAIL_ALLOW_SPAM_TRASH=false


# ---------------------------------------------------------------------
# Frontend base URL — OPTIONAL but recommended in production
# ---------------------------------------------------------------------
# Where the OAuth callback should redirect AFTER the Slack handshake
# completes. If unset, the backend falls back to the first entry in
# CORS_ORIGINS, which is fine for local dev but fragile in prod.
#
# LOCAL:      http://localhost:5173
# PRODUCTION: https://your-frontend.vercel.app
FRONTEND_BASE_URL=http://localhost:5173


# ---------------------------------------------------------------------
# CORS — REQUIRED in production
# ---------------------------------------------------------------------
# Comma-separated list of allowed browser origins. Set this to your
# DEPLOYED frontend URL(s) in production. Wildcard ("*") is NOT
# supported because credentials/auth headers can't be sent with
# wildcard origins anyway.
#
# LOCAL:
#     http://localhost:3000,http://localhost:5173
# PRODUCTION (multiple OK):
#     https://your-frontend.vercel.app,https://staging-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ---------------------------------------------------------------------
# Slack ingestion (CLI / scheduler legacy fallback) — OPTIONAL
# ---------------------------------------------------------------------
# Pre-Phase-3 single-workspace mode. The new per-workspace flow
# stores bot_tokens in Supabase (slack_installations); these env vars
# are only used by the standalone CLI `python -m ingestion.ingest_slack`.
# Leave blank in production deployments that use per-workspace OAuth.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_IDS=

# HydraDB ingestion tuning.
SLACK_LIMIT_PER_CHANNEL=500
HYDRADB_BATCH_SIZE=50
FORCE_REINGEST=false

# Legacy per-process HydraDB sub-tenant (only used by the CLI path).
HYDRADB_SUB_TENANT_ID=slack-second-brain
HYDRADB_BASE_URL=https://api.hydradb.com


# ---------------------------------------------------------------------
# OpenAI / model — OPTIONAL
# ---------------------------------------------------------------------
# Override the base URL to point at an OpenAI-compatible provider
# (OpenRouter, Together, Groq, etc.). The model name must be valid
# for whatever endpoint you point at.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500


# ---------------------------------------------------------------------
# Realtime + scheduled ingestion — OPTIONAL
# ---------------------------------------------------------------------
# REALTIME_INGEST_ENABLED gates the /slack/events Phase 5 path.
# AUTO_INGEST gates the APScheduler background sweep (Phase 4).
REALTIME_INGEST_ENABLED=true
AUTO_INGEST=false
AUTO_INGEST_INTERVAL_MINUTES=15
AUTO_INGEST_RUN_ON_STARTUP=false


# ---------------------------------------------------------------------
# Retrieval / caching / rate limiting — OPTIONAL
# ---------------------------------------------------------------------
DEBUG_RECALL=false
QUERY_CACHE_ENABLED=true
RATE_LIMIT_PER_5_MIN=20


# ---------------------------------------------------------------------
# Observability — OPTIONAL
# ---------------------------------------------------------------------
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR. JSON logs ship to stdout
# in production (Render/Railway capture them automatically).
LOG_LEVEL=INFO

# ENVIRONMENT is echoed in /api/health so dashboards can distinguish
# prod vs preview vs local. Free-form string; common values:
#     local | preview | staging | production
ENVIRONMENT=local

# APP_VERSION is also echoed in /api/health. Set this to your build
# commit SHA -- Render exposes it as RENDER_GIT_COMMIT and Railway as
# RAILWAY_GIT_COMMIT_SHA automatically, so you usually don't need to
# set APP_VERSION explicitly.
APP_VERSION=